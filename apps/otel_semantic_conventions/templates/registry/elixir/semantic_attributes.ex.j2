{%- import 'common.j2' as c %}
{%- set file_name = ctx.output ~ c.file_name(ctx.id) ~ ".ex" -%}
{{ template.set_file_name(file_name) }}
{%- set module_name = ctx.id | pascal_case | acronym -%}
{%- set module_namespace = "Otel.SemConv.Attributes" -%}
defmodule {{ module_namespace }}.{{ module_name }} do
  # This is an auto-generated file
  @moduledoc """
  OpenTelemetry Semantic Conventions for {{ ctx.id | title | acronym }} attributes.
  """
{%- for attribute in ctx.attributes %}
  {%- if attribute.type is mapping %}

  @typedoc """
  {{ c.strong_reqs(c.strip_spec_links(attribute.brief | trim | replace("\n", "\n  "))) }}
  """
  @type {{ c.func_name(attribute.name) }}_values :: {{ c.enum_type_map(attribute.type.members) }}
  {%- endif %}

  @doc """
  {{ c.strong_reqs(c.strip_spec_links(attribute.brief | trim | replace("\n", "\n  "))) }}

      iex> {{ module_namespace }}.{{ module_name }}.{{ c.func_name(attribute.name) }}()
      {{ c.to_string_literal(attribute.name) }}
  """
  @spec {{ c.func_name(attribute.name) }} :: String.t()
  def {{ c.func_name(attribute.name) }} do
    {{ c.to_string_literal(attribute.name) }}
  end
  {%- if attribute.type is mapping %}

  @doc """
  Enum values for `{{ c.func_name(attribute.name) }}`.

      iex> {{ module_namespace }}.{{ module_name }}.{{ c.func_name(attribute.name) }}_values()[{{ c.to_atom(c.first_stable_member(attribute.type.members)) }}]
      {{ c.first_stable_member_value(attribute.type.members) }}
  """
  @spec {{ c.func_name(attribute.name) }}_values :: {{ c.func_name(attribute.name) }}_values()
  def {{ c.func_name(attribute.name) }}_values do
    {{ c.enum_to_map(attribute.type.members) }}
  end
  {%- endif %}
{% endfor %}
end
